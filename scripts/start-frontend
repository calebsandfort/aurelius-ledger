#!/usr/bin/env bash
set -e
WORKTREE_ROOT="${WM_WORKTREE_PATH:-$(cd "$(dirname "$0")/.." && pwd)}"

_load_dotenv() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" || "$line" == \#* || "$line" != *=* ]] && continue
    local key="${line%%=*}"
    local value="${line#*=}"
    [[ "$value" == '"'*'"' ]] && value="${value:1:${#value}-2}"
    [[ "$value" == "'"*"'" ]] && value="${value:1:${#value}-2}"
    export "$key=$value"
  done < "$file"
}

_load_dotenv "${WORKTREE_ROOT}/.env"
_load_dotenv "${WORKTREE_ROOT}/.env.local"
_load_dotenv "${WORKTREE_ROOT}/frontend/.env"
_load_dotenv "${WORKTREE_ROOT}/frontend/.env.local"

cd "${WORKTREE_ROOT}/frontend"
exec pnpm dev --port "${FRONTEND_PORT:-3000}"
