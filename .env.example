# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aurelius-ledger
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aurelius-ledger

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# LangSmith tracing (backend only)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-api-key
LANGSMITH_PROJECT="Aurelius-Ledger"

# Backend
BACKEND_URL=http://localhost:8000

# Ports (override in .env.local for worktree isolation — auto-generated by scripts/worktree-env)
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
